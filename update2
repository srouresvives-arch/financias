      const [loadingPrices, setLoadingPrices] = useState({});
      const [analysis, setAnalysis] = useState(null);
      const [loadingAnalysis, setLoadingAnalysis] = useState(false);
      const [chartData, setChartData] = useState(null);
      const [loadingChart, setLoadingChart] = useState(false);

      // Fetch price from Yahoo Finance via proxy-free alternative
      const fetchPrice = async (ticker) => {
        setLoadingPrices(p => ({...p, [ticker]: true}));
        try {
          const url = `https://api.anthropic.com/v1/messages`;
          const res = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              model: 'claude-sonnet-4-20250514',
              max_tokens: 200,
              tools: [{ type: 'web_search_20250305', name: 'web_search' }],
              messages: [{ role: 'user', content: `Search for the current stock price of ${ticker}. Return ONLY a JSON object like: {"price": 123.45, "change": 1.23, "changePercent": 0.5, "currency": "USD"} with no other text.` }]
            })
          });
          const data = await res.json();
          const text = data.content.map(c => c.text || '').join('');
          const match = text.match(/\{[^}]+\}/);
          if (match) {
            const parsed = JSON.parse(match[0]);
            setPrices(p => ({...p, [ticker]: parsed}));
          }
        } catch(e) {
          setPrices(p => ({...p, [ticker]: { price: null, error: true }}));
        }
        setLoadingPrices(p => ({...p, [ticker]: false}));
      };

      const fetchAllPrices = () => {
        investments.forEach(inv => fetchPrice(inv.ticker));
      };

      useEffect(() => { if (investments.length > 0) fetchAllPrices(); }, [investments.length]);

      const fetchChart = async (ticker) => {
        setLoadingChart(true);
        try {
          const res = await fetch('https://api.anthropic.com/v1/messages', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              model: 'claude-sonnet-4-20250514',
              max_tokens: 500,
              tools: [{ type: 'web_search_20250305', name: 'web_search' }],
              messages: [{ role: 'user', content: `Search for ${ticker} stock price history for the last 30 days. Give me approximate weekly closing prices. Return ONLY a JSON array like: [{"date":"Jan W1","price":150.2},{"date":"Jan W2","price":152.1},...] for the last 8 data points. No other text.` }]
            })
          });
          const data = await res.json();
          const text = data.content.map(c => c.text || '').join('');
          const match = text.match(/\[[^\]]+\]/s);
          if (match) setChartData(JSON.parse(match[0]));
        } catch(e) {}
        setLoadingChart(false);
      };

      const getAnalysis = async (inv) => {
        setLoadingAnalysis(true); setAnalysis(null);
        const p = prices[inv.ticker];
        const currentVal = p?.price ? (p.price * parseFloat(inv.shares)) : null;
        const invested = parseFloat(inv.shares) * parseFloat(inv.buyPrice);
        const pl = currentVal ? currentVal - invested : null;
        const plPct = pl ? ((pl / invested) * 100).toFixed(1) : null;

        try {
          const res = await fetch('https://api.anthropic.com/v1/messages', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              model: 'claude-sonnet-4-20250514',
              max_tokens: 600,
              tools: [{ type: 'web_search_20250305', name: 'web_search' }],
              messages: [{ role: 'user', content: `Search for recent news and analysis about ${inv.ticker} (${inv.company}) stock. The user invested ${inv.currency}${invested.toFixed(2)} at ${inv.buyPrice} per share on ${inv.buyDate}. ${pl !== null ? `Current P&L: ${plPct}% (${pl >= 0 ? '+' : ''}${inv.currency}${pl.toFixed(2)}).` : ''} Give me a brief, honest opinion in 3-4 sentences: recent performance, any notable news, and whether you'd lean towards hold/buy more/trim. Be concise and direct. Speak in first person casual Spanish (tuteo). Mention this is just your opinion, not financial advice.` }]
            })
          });
          const data = await res.json();
          const text = data.content.map(c => c.text || '').join('');
          setAnalysis(text);
        } catch(e) { setAnalysis('Error al obtener análisis. Inténtalo de nuevo.'); }
        setLoadingAnalysis(false);
      };

      const addInvestment = () => {
        if (newInv.ticker && newInv.shares && newInv.buyPrice) {
          const inv = { id: Date.now(), ...newInv, ticker: newInv.ticker.toUpperCase(), shares: parseFloat(newInv.shares), buyPrice: parseFloat(newInv.buyPrice) };
          updateInvestments([...investments, inv]);
          setNewInv({ ticker: '', company: '', shares: '', buyPrice: '', buyDate: '', currency: 'GBP' });
          setShowAdd(false);
          setTimeout(() => fetchPrice(inv.ticker), 500);
        }
      };

      const delInv = (id) => { if (confirm('¿Eliminar esta inversión?')) updateInvestments(investments.filter(i => i.id !== id)); };

      const totalInvested = investments.reduce((s, i) => s + i.shares * i.buyPrice, 0);
      const totalCurrent = investments.reduce((s, i) => {
        const p = prices[i.ticker];
        return s + (p?.price ? p.price * i.shares : i.shares * i.buyPrice);
      }, 0);
      const totalPL = totalCurrent - totalInvested;
      const totalPLPct = totalInvested > 0 ? ((totalPL / totalInvested) * 100) : 0;

      // Mini sparkline SVG
      const Sparkline = ({ data, positive }) => {
        if (!data || data.length < 2) return null;
        const prices = data.map(d => d.price);
        const min = Math.min(...prices), max = Math.max(...prices);
        const range = max - min || 1;
        const w = 200, h = 60;
        const points = prices.map((p, i) => `${(i / (prices.length-1)) * w},${h - ((p-min)/range)*h}`).join(' ');
        return (
          <svg width={w} height={h} style={{display:'block'}}>
            <polyline points={points} fill="none" stroke={positive ? '#22d3a5' : '#ff6b6b'} strokeWidth={2} strokeLinejoin="round" />
          </svg>
        );
      };

      return (
        <div style={{paddingTop:8,display:'flex',flexDirection:'column',gap:14}}>
          <div style={{display:'flex',justifyContent:'space-between',alignItems:'center'}}>
            <h2 style={{margin:0,fontSize:22,fontWeight:700}}>Inversiones</h2>
            <div style={{display:'flex',gap:8}}>
              <button onClick={fetchAllPrices} style={{background:'#1e2130',border:'1px solid #2a2d3a',color:'#888',borderRadius:10,padding:'10px 12px',cursor:'pointer',display:'flex',alignItems:'center'}}><RefreshIcon /></button>
              <button onClick={() => setShowAdd(true)} className="btn-primary" style={{width:'auto',padding:'10px 16px',display:'flex',alignItems:'center',gap:6}}><PlusIcon /> Añadir</button>
            </div>
          </div>

          {/* Portfolio summary */}
          {investments.length > 0 && (
            <div style={{background:'linear-gradient(135deg,#0f2922,#0d1f2d)',borderRadius:20,padding:'20px',border:'1px solid #1a3a30'}}>
              <p style={{margin:'0 0 2px',fontSize:11,color:'#555',textTransform:'uppercase',letterSpacing:1}}>Portfolio Total</p>
              <p style={{margin:'0 0 12px',fontSize:36,fontWeight:700,fontFamily:'DM Mono',color:'#fff'}}>£{totalCurrent.toFixed(2)}</p>
              <div style={{display:'flex',gap:16}}>
                <div><p style={{margin:'0 0 2px',fontSize:11,color:'#555'}}>Invertido</p><p style={{margin:0,fontFamily:'DM Mono',fontWeight:600,color:'#f0f0f0',fontSize:15}}>£{totalInvested.toFixed(2)}</p></div>
                <div><p style={{margin:'0 0 2px',fontSize:11,color:'#555'}}>P&L</p><p style={{margin:0,fontFamily:'DM Mono',fontWeight:600,color:totalPL>=0?'#22d3a5':'#ff6b6b',fontSize:15}}>{totalPL>=0?'+':''}£{totalPL.toFixed(2)} ({totalPLPct>=0?'+':''}{totalPLPct.toFixed(1)}%)</p></div>
              </div>
            </div>
          )}

          {showAdd && (
            <div className="card" style={{padding:20,display:'flex',flexDirection:'column',gap:12}}>
              <h3 style={{margin:'0 0 4px',fontSize:15,fontWeight:600}}>Nueva Posición</h3>
              <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:10}}>
                <div><label style={{fontSize:11,color:'#555',display:'block',marginBottom:5}}>Ticker (ej: AAPL)</label><input type="text" placeholder="GOOGL" value={newInv.ticker} onChange={e => setNewInv({...newInv, ticker: e.target.value.toUpperCase()})} className="input-dark" style={{textTransform:'uppercase'}} /></div>
                <div><label style={{fontSize:11,color:'#555',display:'block',marginBottom:5}}>Empresa</label><input type="text" placeholder="Google" value={newInv.company} onChange={e => setNewInv({...newInv, company: e.target.value})} className="input-dark" /></div>
                <div><label style={{fontSize:11,color:'#555',display:'block',marginBottom:5}}>Nº acciones</label><input type="number" inputMode="decimal" placeholder="10" value={newInv.shares} onChange={e => setNewInv({...newInv, shares: e.target.value})} className="input-dark" /></div>
                <div><label style={{fontSize:11,color:'#555',display:'block',marginBottom:5}}>Precio compra</label><input type="number" inputMode="decimal" placeholder="150.00" value={newInv.buyPrice} onChange={e => setNewInv({...newInv, buyPrice: e.target.value})} className="input-dark" /></div>
                <div><label style={{fontSize:11,color:'#555',display:'block',marginBottom:5}}>Fecha compra</label><input type="text" placeholder="Enero 2025" value={newInv.buyDate} onChange={e => setNewInv({...newInv, buyDate: e.target.value})} className="input-dark" /></div>
                <div><label style={{fontSize:11,color:'#555',display:'block',marginBottom:5}}>Moneda</label>
                  <select value={newInv.currency} onChange={e => setNewInv({...newInv, currency: e.target.value})} className="input-dark" style={{appearance:'none',background:'#0f1117'}}>
                    <option value="GBP">£ GBP</option><option value="EUR">€ EUR</option><option value="USD">$ USD</option>
                  </select>
                </div>
              </div>
              <div style={{display:'flex',gap:10,marginTop:4}}><button onClick={addInvestment} className="btn-primary">Añadir</button><button onClick={() => setShowAdd(false)} className="btn-secondary">Cancelar</button></div>
            </div>
          )}

          {investments.length === 0 && !showAdd && (
            <div className="card" style={{padding:40,textAlign:'center'}}>
              <p style={{fontSize:36,margin:'0 0 8px'}}>📈</p>
              <p style={{color:'#555',fontSize:14,margin:0}}>Sin inversiones aún.</p>
              <p style={{color:'#444',fontSize:12,margin:'4px 0 0'}}>Añade tus posiciones para hacer seguimiento.</p>
            </div>
          )}

          {/* Investment cards */}
          {investments.map(inv => {
            const p = prices[inv.ticker];
            const isLoading = loadingPrices[inv.ticker];
            const invested = inv.shares * inv.buyPrice;
            const currentVal = p?.price ? p.price * inv.shares : null;
            const pl = currentVal ? currentVal - invested : null;
            const plPct = pl ? ((pl / invested) * 100) : null;
            const isPos = pl !== null ? pl >= 0 : true;

            return (
              <div key={inv.id} className="card" style={{padding:20}}>
                <div style={{display:'flex',justifyContent:'space-between',alignItems:'flex-start',marginBottom:14}}>
                  <div>
                    <div style={{display:'flex',alignItems:'center',gap:8,marginBottom:4}}>
                      <span style={{fontSize:18,fontWeight:800,fontFamily:'DM Mono',color:'#f0f0f0'}}>{inv.ticker}</span>
                      <span className="tag">{inv.currency}</span>
                    </div>
                    <p style={{margin:0,fontSize:13,color:'#666'}}>{inv.company || 'Sin nombre'}</p>
                    <p style={{margin:'2px 0 0',fontSize:11,color:'#444'}}>Comprado: {inv.buyDate || 'N/A'} · {inv.shares} acc. @ {inv.currency === 'GBP' ? '£' : inv.currency === 'EUR' ? '€' : '$'}{inv.buyPrice}</p>
                  </div>
                  <button onClick={() => delInv(inv.id)} style={{background:'none',border:'none',color:'#ff6b6b',cursor:'pointer',opacity:0.6,padding:4}}><TrashIcon /></button>
                </div>

                {/* Price block */}
                <div className="card-light" style={{padding:'12px 14px',marginBottom:12}}>
                  {isLoading ? (
                    <div style={{display:'flex',gap:8,alignItems:'center'}}>
                      <div className="loading-shimmer" style={{width:80,height:24}} />
                      <span style={{fontSize:12,color:'#555'}}>Actualizando...</span>
                    </div>
                  ) : p?.error ? (
                    <div style={{display:'flex',justifyContent:'space-between',alignItems:'center'}}>
                      <span style={{fontSize:12,color:'#ff6b6b'}}>Error al cargar precio</span>
                      <button onClick={() => fetchPrice(inv.ticker)} style={{background:'none',border:'none',color:'#6c63ff',cursor:'pointer',fontSize:12}}>Reintentar</button>
                    </div>
                  ) : p?.price ? (
                    <div style={{display:'flex',justifyContent:'space-between',alignItems:'flex-end'}}>
                      <div>
                        <p style={{margin:'0 0 2px',fontSize:11,color:'#555'}}>Precio actual</p>
                        <p style={{margin:0,fontSize:24,fontWeight:700,fontFamily:'DM Mono',color:'#f0f0f0'}}>{inv.currency === 'GBP' ? '£' : inv.currency === 'EUR' ? '€' : '$'}{p.price?.toFixed(2)}</p>
                      </div>
                      <div style={{textAlign:'right'}}>
                        <span className={isPos ? 'tag-green' : 'tag-red'}>{isPos?'▲':'▼'} {Math.abs(p.changePercent || 0).toFixed(2)}% hoy</span>
                      </div>
                    </div>
                  ) : (
                    <div style={{display:'flex',justifyContent:'space-between',alignItems:'center'}}>
                      <span style={{fontSize:13,color:'#555'}}>Sin precio</span>
                      <button onClick={() => fetchPrice(inv.ticker)} style={{background:'none',border:'none',color:'#6c63ff',cursor:'pointer',display:'flex',alignItems:'center',gap:4,fontSize:12}}><RefreshIcon /> Cargar</button>
                    </div>
                  )}
                </div>

                {/* P&L */}
                {pl !== null && (
                  <div style={{display:'grid',gridTemplateColumns:'1fr 1fr 1fr',gap:8,marginBottom:12}}>
                    {[['Invertido',`${inv.currency === 'GBP' ? '£' : inv.currency === 'EUR' ? '€' : '$'}${invested.toFixed(2)}`,'#888'],['Ahora',`${inv.currency === 'GBP' ? '£' : inv.currency === 'EUR' ? '€' : '$'}${currentVal.toFixed(2)}`,isPos?'#22d3a5':'#ff6b6b'],['P&L',`${pl>=0?'+':''}${plPct.toFixed(1)}%`,isPos?'#22d3a5':'#ff6b6b']].map(([label,val,color]) => (
                      <div key={label} className="card-light" style={{padding:'8px 10px',textAlign:'center'}}>
                        <p style={{margin:'0 0 2px',fontSize:9,color:'#555',fontWeight:500}}>{label}</p>
                        <p style={{margin:0,fontSize:12,fontWeight:700,fontFamily:'DM Mono',color}}>{val}</p>
                      </div>
                    ))}
                  </div>
                )}

                {/* Chart & Analysis buttons */}
                <div style={{display:'flex',gap:8}}>
                  <button
                    onClick={() => { if (selectedInv === inv.id) { setSelectedInv(null); setChartData(null); setAnalysis(null); } else { setSelectedInv(inv.id); setAnalysis(null); setChartData(null); fetchChart(inv.ticker); } }}
                    style={{flex:1,background:'rgba(108,99,255,0.1)',color:'#6c63ff',border:'1px solid rgba(108,99,255,0.2)',borderRadius:10,padding:'10px',cursor:'pointer',fontSize:12,fontWeight:600,display:'flex',alignItems:'center',justifyContent:'center',gap:6}}
                  >
                    {selectedInv === inv.id ? <CloseIcon /> : <ChartIcon />} Gráfico
                  </button>
                  <button
                    onClick={() => { setSelectedInv(inv.id); getAnalysis(inv); }}
                    style={{flex:1,background:'rgba(34,211,165,0.08)',color:'#22d3a5',border:'1px solid rgba(34,211,165,0.15)',borderRadius:10,padding:'10px',cursor:'pointer',fontSize:12,fontWeight:600,display:'flex',alignItems:'center',justifyContent:'center',gap:6}}
                  >
                    <StarIcon /> Claude
                  </button>
                </div>

                {/* Chart */}
                {selectedInv === inv.id && (
                  <div style={{marginTop:12}}>
                    {loadingChart ? (
                      <div style={{padding:20,textAlign:'center'}}>
                        <div className="loading-shimmer" style={{height:60,borderRadius:8}} />
                        <p style={{fontSize:12,color:'#555',marginTop:8}}>Cargando historial...</p>
                      </div>
                    ) : chartData ? (
                      <div className="card-light" style={{padding:16}}>
                        <p style={{fontSize:11,color:'#555',marginBottom:8,fontWeight:500}}>Últimas semanas</p>
                        <Sparkline data={chartData} positive={isPos} />
                        <div style={{display:'flex',justifyContent:'space-between',marginTop:4}}>
                          <span style={{fontSize:10,color:'#555',fontFamily:'DM Mono'}}>{chartData[0]?.date}</span>
                          <span style={{fontSize:10,color:'#555',fontFamily:'DM Mono'}}>{chartData[chartData.length-1]?.date}</span>
                        </div>
                      </div>
                    ) : null}
                  </div>
                )}

                {/* Claude Analysis */}
                {selectedInv === inv.id && (loadingAnalysis || analysis) && (
                  <div style={{marginTop:12,background:'rgba(34,211,165,0.05)',border:'1px solid rgba(34,211,165,0.12)',borderRadius:12,padding:16}}>
                    <div style={{display:'flex',alignItems:'center',gap:6,marginBottom:10}}>
                      <StarIcon />
                      <span style={{fontSize:12,fontWeight:600,color:'#22d3a5'}}>Opinión de Claude</span>
                      <span style={{fontSize:10,color:'#444'}}>(no es asesoramiento financiero)</span>
                    </div>
                    {loadingAnalysis ? (
                      <div style={{display:'flex',flexDirection:'column',gap:6}}>
                        {[100,80,90,60].map((w,i) => <div key={i} className="loading-shimmer" style={{height:12,borderRadius:4,width:`${w}%`}} />)}
                      </div>
                    ) : (
                      <p style={{margin:0,fontSize:13,color:'#b0b0b0',lineHeight:1.6}}>{analysis}</p>
                    )}
                  </div>
                )}
              </div>
            );
          })}
        </div>
      );
    };

    // ─── BOTTOM NAV ───────────────────────────────────────────────────────────
    const BottomNav = ({ currentView, setCurrentView }) => {
      const tabs = [
        { id: 'home', label: 'Inicio', icon: <HomeIcon /> },
        { id: 'accounts', label: 'Cuentas', icon: <WalletIcon /> },
        { id: 'expenses', label: 'Gastos', icon: <TrendingIcon /> },
        { id: 'investments', label: 'Inversión', icon: <InvestIcon /> },
        { id: 'stats', label: 'Stats', icon: <ChartIcon /> },
        { id: 'goals', label: 'Metas', icon: <TargetIcon /> },
      ];
      const active = (id) => currentView === id || (id === 'home' && currentView === 'addSaving');

      return (
        <div style={{position:'fixed',bottom:0,left:0,right:0,background:'rgba(15,17,23,0.95)',backdropFilter:'blur(20px)',borderTop:'1px solid #1e2130',padding:'8px 4px',zIndex:100}}>
          <div style={{display:'flex',justifyContent:'space-around',maxWidth:480,margin:'0 auto'}}>
            {tabs.map(tab => (
              <button key={tab.id} onClick={() => setCurrentView(tab.id)} className={`nav-btn ${active(tab.id) ? 'active' : ''}`}>
                {tab.icon}
                <span>{tab.label}</span>
              </button>
            ))}
          </div>
        </div>
      );
    };

    ReactDOM.render(<FinanceApp />, document.getElementById('root'));
  </script>
</body>
</html>

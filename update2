<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Finanzas">
  <title>Gestor Financiero Personal</title>
  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap');
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    body { margin: 0; padding: 0; font-family: 'DM Sans', -apple-system, sans-serif; background: #0f1117; color: #f0f0f0; overscroll-behavior: none; }
    input[type=number]::-webkit-inner-spin-button, input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
    input[type=number] { -moz-appearance: textfield; }
    .card { background: #1a1d27; border: 1px solid #2a2d3a; border-radius: 16px; }
    .card-light { background: #1e2130; border: 1px solid #2a2d3a; border-radius: 12px; }
    .accent { color: #6c63ff; }
    .accent-bg { background: #6c63ff; }
    .accent-border { border-color: #6c63ff; }
    .green { color: #22d3a5; }
    .green-bg { background: #22d3a5; }
    .red-c { color: #ff6b6b; }
    .input-dark { background: #0f1117; border: 1px solid #2a2d3a; color: #f0f0f0; border-radius: 10px; padding: 10px 14px; width: 100%; font-family: 'DM Sans', sans-serif; font-size: 15px; outline: none; transition: border-color 0.2s; }
    .input-dark:focus { border-color: #6c63ff; }
    .btn-primary { background: #6c63ff; color: white; border: none; border-radius: 10px; padding: 12px 20px; font-family: 'DM Sans', sans-serif; font-weight: 600; font-size: 15px; cursor: pointer; width: 100%; transition: opacity 0.2s; }
    .btn-primary:active { opacity: 0.8; }
    .btn-secondary { background: #2a2d3a; color: #f0f0f0; border: none; border-radius: 10px; padding: 12px 20px; font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 15px; cursor: pointer; width: 100%; }
    .nav-btn { display: flex; flex-direction: column; align-items: center; gap: 3px; padding: 8px 12px; border-radius: 12px; border: none; background: transparent; color: #666; cursor: pointer; transition: all 0.2s; }
    .nav-btn.active { color: #6c63ff; background: rgba(108,99,255,0.12); }
    .nav-btn span { font-size: 10px; font-weight: 600; font-family: 'DM Sans', sans-serif; letter-spacing: 0.3px; }
    .mono { font-family: 'DM Mono', monospace; }
    .candle-green { fill: #22d3a5; stroke: #22d3a5; }
    .candle-red { fill: #ff6b6b; stroke: #ff6b6b; }
    .tag { background: rgba(108,99,255,0.15); color: #6c63ff; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .tag-green { background: rgba(34,211,165,0.12); color: #22d3a5; padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .tag-red { background: rgba(255,107,107,0.12); color: #ff6b6b; padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .sync-dot { width: 8px; height: 8px; border-radius: 50%; background: #22d3a5; display: inline-block; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.8)} }
    .loading-shimmer { background: linear-gradient(90deg, #1a1d27 25%, #2a2d3a 50%, #1a1d27 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 8px; }
    @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
    select option { background: #1a1d27; color: #f0f0f0; }
    ::-webkit-scrollbar { width: 4px; } ::-webkit-scrollbar-track { background: transparent; } ::-webkit-scrollbar-thumb { background: #2a2d3a; border-radius: 2px; }
  </style>
</head>
<body>
  <div id="root"></div>
  <script type="text/babel">
    const { useState, useEffect, useRef, useCallback } = React;

    // ─── STORAGE HELPERS (Claude persistent storage) ─────────────────────────
    const storage = window.storage;

    const loadData = async (key, fallback) => {
      try {
        const res = await storage.get(key);
        return res ? JSON.parse(res.value) : fallback;
      } catch { return fallback; }
    };

    const saveData = async (key, value) => {
      try { await storage.set(key, JSON.stringify(value)); } catch(e) { console.error('Storage error', e); }
    };

    // ─── ICONS ────────────────────────────────────────────────────────────────
    const Icon = ({ d, size = 22, stroke = 2 }) => (
      <svg width={size} height={size} fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={stroke} d={d} />
      </svg>
    );
    const HomeIcon = () => <Icon d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />;
    const WalletIcon = () => <Icon d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />;
    const TrendingIcon = () => <Icon d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />;
    const ChartIcon = () => <Icon d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />;
    const TargetIcon = () => <Icon d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />;
    const PlusIcon = () => <Icon d="M12 4v16m8-8H4" size={18} />;
    const EditIcon = () => <Icon d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" size={16} />;
    const TrashIcon = () => <Icon d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" size={16} />;
    const InvestIcon = () => <Icon d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" />;
    const StarIcon = () => <Icon d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" size={14} />;
    const RefreshIcon = () => <Icon d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" size={16} />;
    const CloseIcon = () => <Icon d="M6 18L18 6M6 6l12 12" size={18} />;

    // ─── MAIN APP ─────────────────────────────────────────────────────────────
    const FinanceApp = () => {
      const [currentView, setCurrentView] = useState('home');
      const [loading, setLoading] = useState(true);
      const [syncing, setSyncing] = useState(false);

      const [distribution, setDistribution] = useState({
        madre: { percentage: 20, label: 'A tu madre' },
        inversion: { percentage: 10, label: 'Inversión (ETF)' },
        ahorro: { percentage: 40, label: 'Ahorro intocable' },
        caprichos: { percentage: 30, label: 'Caprichos/Emergencias' }
      });

      const [accounts, setAccounts] = useState([
        { id: 1, name: 'Santander', type: 'current', balance: 1211.53 }
      ]);

      const [monthlySavings, setMonthlySavings] = useState([]);
      const [expenseCategories, setExpenseCategories] = useState([
        { id: 1, name: 'Renta' }, { id: 2, name: 'Agua' }, { id: 3, name: 'Electricidad' },
        { id: 4, name: 'Council Tax' }, { id: 5, name: 'Gimnasio' }, { id: 6, name: 'Víveres' },
        { id: 7, name: 'WiFi' }, { id: 8, name: 'Gasolina' }
      ]);
      const [monthlyExpenses, setMonthlyExpenses] = useState([]);
      const [motherDebt, setMotherDebt] = useState({ total: 3800, paid: 0 });
      const [investments, setInvestments] = useState([]);

      // Load all data from persistent storage
      useEffect(() => {
        (async () => {
          setLoading(true);
          const [d, a, ms, ec, me, md, inv] = await Promise.all([
            loadData('fin_distribution', null),
            loadData('fin_accounts', null),
            loadData('fin_monthly_savings', []),
            loadData('fin_expense_cats', null),
            loadData('fin_monthly_expenses', []),
            loadData('fin_mother_debt', { total: 3800, paid: 0 }),
            loadData('fin_investments', []),
          ]);
          if (d) setDistribution(d);
          if (a) setAccounts(a);
          if (ms) setMonthlySavings(ms);
          if (ec) setExpenseCategories(ec);
          if (me) setMonthlyExpenses(me);
          if (md) setMotherDebt(md);
          if (inv) setInvestments(inv);
          setLoading(false);
        })();
      }, []);

      // Persist helpers
      const persist = async (key, val) => { setSyncing(true); await saveData(key, val); setTimeout(() => setSyncing(false), 800); };
      const updateDistribution = v => { setDistribution(v); persist('fin_distribution', v); };
      const updateAccounts = v => { setAccounts(v); persist('fin_accounts', v); };
      const updateMonthlySavings = v => { setMonthlySavings(v); persist('fin_monthly_savings', v); };
      const updateExpenseCategories = v => { setExpenseCategories(v); persist('fin_expense_cats', v); };
      const updateMonthlyExpenses = v => { setMonthlyExpenses(v); persist('fin_monthly_expenses', v); };
      const updateMotherDebt = v => { setMotherDebt(v); persist('fin_mother_debt', v); };
      const updateInvestments = v => { setInvestments(v); persist('fin_investments', v); };

      const totalBalance = accounts.reduce((sum, acc) => sum + acc.balance, 0);
      const totalSavingsAccounts = accounts.filter(a => a.type === 'savings').reduce((sum, a) => sum + a.balance, 0);
      const remainingDebt = motherDebt.total - motherDebt.paid;

      if (loading) return (
        <div style={{display:'flex',flexDirection:'column',alignItems:'center',justifyContent:'center',minHeight:'100vh',gap:16}}>
          <div style={{width:48,height:48,borderRadius:'50%',border:'3px solid #2a2d3a',borderTop:'3px solid #6c63ff',animation:'spin 1s linear infinite'}} />
          <style>{`@keyframes spin{to{transform:rotate(360deg)}}`}</style>
          <p style={{color:'#666',fontSize:14}}>Cargando tus datos...</p>
        </div>
      );

      const sharedProps = { distribution, updateDistribution, accounts, updateAccounts, monthlySavings, updateMonthlySavings, expenseCategories, updateExpenseCategories, monthlyExpenses, updateMonthlyExpenses, motherDebt, updateMotherDebt, investments, updateInvestments, totalBalance, totalSavingsAccounts, remainingDebt, setCurrentView };

      return (
        <div style={{minHeight:'100vh',background:'#0f1117',paddingBottom:90}}>
          {/* Status bar sync indicator */}
          <div style={{position:'fixed',top:0,right:0,padding:'8px 14px',zIndex:100,display:'flex',alignItems:'center',gap:6}}>
            <span className="sync-dot" style={{background: syncing ? '#f59e0b' : '#22d3a5'}} />
            <span style={{fontSize:10,color:'#444',fontFamily:'DM Mono'}}>{syncing ? 'sync...' : 'sync ✓'}</span>
          </div>

          <div style={{maxWidth:480,margin:'0 auto',padding:'16px 16px 0'}}>
            {currentView === 'home' && <HomeView {...sharedProps} />}
            {currentView === 'addSaving' && <AddSavingView {...sharedProps} />}
            {currentView === 'accounts' && <AccountsView {...sharedProps} />}
            {currentView === 'expenses' && <ExpensesView {...sharedProps} />}
            {currentView === 'stats' && <StatsView {...sharedProps} />}
            {currentView === 'goals' && <GoalsView {...sharedProps} />}
            {currentView === 'investments' && <InvestmentsView {...sharedProps} />}
          </div>

          <BottomNav currentView={currentView} setCurrentView={setCurrentView} />
        </div>
      );
    };

    // ─── HOME VIEW ────────────────────────────────────────────────────────────
    const HomeView = ({ distribution, updateDistribution, accounts, totalBalance, monthlySavings, setCurrentView }) => {
      const [editingDist, setEditingDist] = useState(null);
      const [tempPct, setTempPct] = useState('');

      const savePct = (key) => {
        const v = parseInt(tempPct);
        if (!isNaN(v) && v >= 0 && v <= 100) {
          updateDistribution({ ...distribution, [key]: { ...distribution[key], percentage: v } });
        }
        setEditingDist(null); setTempPct('');
      };

      const distColors = { madre: '#ff6b6b', inversion: '#22d3a5', ahorro: '#6c63ff', caprichos: '#f59e0b' };

      return (
        <div style={{paddingTop:8,display:'flex',flexDirection:'column',gap:16}}>
          {/* Hero balance */}
          <div style={{background:'linear-gradient(135deg,#1e1b4b,#312e81)',borderRadius:20,padding:'24px 20px',border:'1px solid #3730a3',position:'relative',overflow:'hidden'}}>
            <div style={{position:'absolute',top:-20,right:-20,width:100,height:100,borderRadius:'50%',background:'rgba(108,99,255,0.15)'}} />
            <div style={{position:'absolute',bottom:-30,left:-10,width:80,height:80,borderRadius:'50%',background:'rgba(34,211,165,0.08)'}} />
            <p style={{fontSize:12,color:'rgba(255,255,255,0.6)',fontWeight:500,letterSpacing:1,textTransform:'uppercase',margin:0}}>Balance Total</p>
            <p style={{fontSize:42,fontWeight:700,margin:'4px 0 0',fontFamily:'DM Mono',color:'#fff'}}>
              £{totalBalance.toFixed(2)}
            </p>
            <div style={{display:'flex',gap:8,marginTop:14,flexWrap:'wrap'}}>
              {accounts.map(acc => (
                <div key={acc.id} style={{background:'rgba(255,255,255,0.08)',borderRadius:10,padding:'6px 12px',backdropFilter:'blur(10px)',border:'1px solid rgba(255,255,255,0.12)'}}>
                  <p style={{margin:0,fontSize:10,color:'rgba(255,255,255,0.5)',fontWeight:500}}>{acc.name}</p>
                  <p style={{margin:0,fontSize:15,fontWeight:700,color:'#fff',fontFamily:'DM Mono'}}>£{acc.balance.toFixed(2)}</p>
                  <p style={{margin:0,fontSize:9,color:'rgba(255,255,255,0.4)'}}>{acc.type === 'current' ? '🏦 Corriente' : acc.type === 'savings' ? '💰 Ahorro' : '📈 Inversión'}</p>
                </div>
              ))}
            </div>
          </div>

          {/* Distribution */}
          <div className="card" style={{padding:20}}>
            <h3 style={{margin:'0 0 16px',fontSize:15,fontWeight:600,color:'#f0f0f0'}}>Distribución Mensual</h3>
            {/* Visual bar */}
            <div style={{height:8,borderRadius:4,overflow:'hidden',display:'flex',marginBottom:16}}>
              {Object.entries(distribution).map(([key, item]) => (
                <div key={key} style={{width:`${item.percentage}%`,background:distColors[key] || '#6c63ff',transition:'width 0.4s'}} />
              ))}
            </div>
            <div style={{display:'flex',flexDirection:'column',gap:8}}>
              {Object.entries(distribution).map(([key, item]) => (
                <div key={key} className="card-light" style={{padding:'10px 14px',display:'flex',alignItems:'center',justifyContent:'space-between'}}>
                  <div style={{display:'flex',alignItems:'center',gap:10}}>
                    <div style={{width:10,height:10,borderRadius:'50%',background:distColors[key] || '#6c63ff',flexShrink:0}} />
                    <span style={{fontSize:14,color:'#c0c0c0'}}>{item.label}</span>
                  </div>
                  {editingDist === key ? (
                    <div style={{display:'flex',alignItems:'center',gap:8}}>
                      <input
                        className="input-dark"
                        type="number"
                        inputMode="numeric"
                        value={tempPct}
                        onChange={e => setTempPct(e.target.value)}
                        style={{width:60,padding:'6px 10px',textAlign:'center'}}
                        autoFocus
                        onBlur={() => savePct(key)}
                        onKeyDown={e => { if (e.key === 'Enter') savePct(key); if (e.key === 'Escape') { setEditingDist(null); setTempPct(''); } }}
                      />
                      <button onClick={() => savePct(key)} style={{background:'#6c63ff',color:'#fff',border:'none',borderRadius:8,padding:'6px 12px',fontSize:13,fontWeight:600,cursor:'pointer'}}>OK</button>
                    </div>
                  ) : (
                    <div style={{display:'flex',alignItems:'center',gap:10}}>
                      <span style={{fontSize:18,fontWeight:700,fontFamily:'DM Mono',color:distColors[key] || '#6c63ff'}}>{item.percentage}%</span>
                      <button onClick={() => { setEditingDist(key); setTempPct(item.percentage.toString()); }} style={{background:'none',border:'none',color:'#444',cursor:'pointer',padding:4}}><EditIcon /></button>
                    </div>
                  )}
                </div>
              ))}
            </div>
          </div>

          {/* Monthly savings */}
          <div className="card" style={{padding:20}}>
            <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:14}}>
              <h3 style={{margin:0,fontSize:15,fontWeight:600,color:'#f0f0f0'}}>Ahorro Mensual</h3>
              <button onClick={() => setCurrentView('addSaving')} style={{background:'rgba(108,99,255,0.15)',color:'#6c63ff',border:'none',borderRadius:8,padding:'6px 12px',fontSize:13,fontWeight:600,cursor:'pointer',display:'flex',alignItems:'center',gap:4}}>
                <PlusIcon /> Añadir
              </button>
            </div>
            {monthlySavings.length === 0 ? (
              <p style={{color:'#444',fontSize:13,textAlign:'center',padding:'12px 0',margin:0}}>Sin registros aún</p>
            ) : (
              <div style={{display:'flex',flexDirection:'column',gap:8}}>
                {monthlySavings.slice(-4).reverse().map(r => (
                  <div key={r.id} className="card-light" style={{padding:'10px 14px',display:'flex',justifyContent:'space-between',alignItems:'center'}}>
                    <span style={{fontSize:14,color:'#c0c0c0'}}>{r.month}</span>
                    <span style={{fontFamily:'DM Mono',fontWeight:600,color:'#22d3a5'}}>£{r.amount}</span>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      );
    };

    // ─── ADD SAVING ───────────────────────────────────────────────────────────
    const AddSavingView = ({ monthlySavings, updateMonthlySavings, setCurrentView }) => {
      const [month, setMonth] = useState('');
      const [amount, setAmount] = useState('');
      const months = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
      const save = () => {
        if (month && amount) { updateMonthlySavings([...monthlySavings, { id: Date.now(), month, amount: parseFloat(amount) }]); setCurrentView('home'); }
      };
      return (
        <div style={{paddingTop:8}}>
          <div style={{display:'flex',alignItems:'center',gap:12,marginBottom:20}}>
            <button onClick={() => setCurrentView('home')} style={{background:'#1e2130',border:'1px solid #2a2d3a',color:'#f0f0f0',borderRadius:10,padding:'8px 14px',cursor:'pointer',fontSize:14}}>← Volver</button>
            <h2 style={{margin:0,fontSize:20,fontWeight:700}}>Registrar Ahorro</h2>
          </div>
          <div className="card" style={{padding:20,display:'flex',flexDirection:'column',gap:14}}>
            <div>
              <label style={{fontSize:12,color:'#666',display:'block',marginBottom:6,fontWeight:500,textTransform:'uppercase',letterSpacing:0.5}}>Mes</label>
              <select value={month} onChange={e => setMonth(e.target.value)} className="input-dark" style={{appearance:'none',background:'#0f1117'}}>
                <option value="">Selecciona mes</option>
                {months.map(m => <option key={m} value={m}>{m}</option>)}
              </select>
            </div>
            <div>
              <label style={{fontSize:12,color:'#666',display:'block',marginBottom:6,fontWeight:500,textTransform:'uppercase',letterSpacing:0.5}}>Cantidad ahorrada (£)</label>
              <input type="number" inputMode="decimal" value={amount} onChange={e => setAmount(e.target.value)} placeholder="0.00" className="input-dark" />
            </div>
            <div style={{display:'flex',gap:10,marginTop:4}}>
              <button onClick={save} className="btn-primary">Guardar</button>
              <button onClick={() => setCurrentView('home')} className="btn-secondary">Cancelar</button>
            </div>
          </div>
        </div>
      );
    };

    // ─── ACCOUNTS VIEW ────────────────────────────────────────────────────────
    const AccountsView = ({ accounts, updateAccounts, totalBalance }) => {
      const [showAdd, setShowAdd] = useState(false);
      const [editingId, setEditingId] = useState(null);
      const [newAcc, setNewAcc] = useState({ name: '', type: 'savings', balance: '' });
      const [tempBalance, setTempBalance] = useState('');

      const addAcc = () => {
        if (newAcc.name && newAcc.balance !== '') {
          updateAccounts([...accounts, { id: Date.now(), ...newAcc, balance: parseFloat(newAcc.balance) }]);
          setNewAcc({ name: '', type: 'savings', balance: '' }); setShowAdd(false);
        }
      };
      const saveBalance = (id) => {
        const v = parseFloat(tempBalance);
        if (!isNaN(v)) updateAccounts(accounts.map(a => a.id === id ? { ...a, balance: v } : a));
        setEditingId(null); setTempBalance('');
      };
      const del = (id) => { if (confirm('¿Eliminar esta cuenta?')) updateAccounts(accounts.filter(a => a.id !== id)); };

      const typeLabel = t => t === 'savings' ? '💰 Ahorro' : t === 'investment' ? '📈 Inversión' : '🏦 Corriente';
      const typeColor = t => t === 'savings' ? '#22d3a5' : t === 'investment' ? '#f59e0b' : '#6c63ff';

      return (
        <div style={{paddingTop:8,display:'flex',flexDirection:'column',gap:14}}>
          <div style={{display:'flex',justifyContent:'space-between',alignItems:'center'}}>
            <div>
